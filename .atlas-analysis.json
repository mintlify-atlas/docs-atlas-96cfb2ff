  "keyFeatures": [
    "Multi-phase orchestration pipeline (PRD → Mermaid → Validation → Figma)",
    "Automated logic validation with 6-criteria scoring system",
    "Support for 8 diagram types (flowchart, sequence, ER, class, state, C4, journey, gantt)",
    "Interactive, batch, and auto validation modes",
    "Figma asset generation with design system support (Material 3, Apple HIG, Tailwind)",
    "Extensible sub-skill architecture",
    "Configuration via YAML with custom design tokens and hooks"
  ],
  "publicApiSurface": [
    "omni-architect.run(options)",
    "skills/prd-parse - PRD Parser skill",
    "skills/mermaid-gen - Mermaid Generator skill",
    "skills/logic-validate - Logic Validator skill",
    "skills/figma-gen - Figma Generator skill",
    "skills/asset-deliver - Asset Delivery skill",
    "CLI: skills run omni-architect",
    "Configuration: .omni-architect.yml",
    "Inputs: prd_source, project_name, figma_file_key, figma_access_token, diagram_types, design_system, validation_mode, validation_threshold, locale",
    "Outputs: parsed_prd, mermaid_diagrams, validation_report, figma_assets, orchestration_log"
  ]
